{
  "expo": {
    "name": "Vasuli",
    "slug": "vasuli",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0F1A",
    "androidStatusBar": {
      "backgroundColor": "#0F0F1A",
      "barStyle": "light-content",
      "translucent": false
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.vasuli.app",
      "usesCleartextTraffic": true,
      "blockedPermissions": [
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.vasuli.app"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "defaultChannel": "vasuli-auto-reminders"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Vasuli to access your contacts so you can fill phone numbers faster."
        }
      ]
    ]
  }
}
