    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-contacts": "~15.0.11",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
